# Copy to .env and set values, or export in the shell.
# --- Cloud (OpenAI) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
# Optional: model name (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Local models (Ollama, LM Studio, etc.) ---
# Base URL of the OpenAI-compatible API (no key needed for most local servers)
OPENAI_BASE_URL=http://localhost:11434/v1
# For LM Studio use http://localhost:1234/v1
OPENAI_MODEL=llama3
# LM Studio: use native streaming to separate reasoning from message (1 = on)
# USE_LM_STUDIO_STREAMING=1
# Max tokens per response (default 4096). Increase if answers get cut off (e.g. 8192).
OPENAI_MAX_TOKENS=4096
# Max run time in milliseconds (runner default 300000 = 5 min). Increase for slow/local models (e.g. 600000 = 10 min, 900000 = 15 min).
MAX_EXECUTION_TIME_MS=900000
